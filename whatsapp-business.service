[Unit]
Description=Viviz WhatsApp Business API
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/whatsapp-business
ExecStart=/home/ubuntu/whatsapp-business/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8003 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
EnvironmentFile=/home/ubuntu/whatsapp-business/.env

[Install]
WantedBy=multi-user.target
