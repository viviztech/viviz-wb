# Meta WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=viviz_webhook_secret_2024
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# App Settings
APP_NAME=Viviz WhatsApp Business
APP_URL=https://wa.viviztech.in
SECRET_KEY=change_this_to_random_secret_key_min_32_chars
ADMIN_EMAIL=admin@viviztech.in
ADMIN_PASSWORD=Admin@1234
